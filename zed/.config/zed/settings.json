{
  // Disable clutter.
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "title_bar": {
    "show_sign_in": false,
  },
  // Git.
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  // Disable AI & Telemetry.
  "disable_ai": true,
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  // Vim.
  "vim_mode": true,
  // Appearance.
  "ui_font_size": 16,
  "buffer_font_size": 15,
  // Theme.
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark",
  },
  // Misc.
  "base_keymap": "VSCode",
}
